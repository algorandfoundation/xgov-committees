# Standalone use: copy this file to .env and fill in values.
# When invoked via the runner, all vars are inherited from the runner's process.env
# (root .env via systemd EnvironmentFile= in prod, or dotenv in dev).

# ─── Invocation (standalone only - runner passes these as CLI args) ────────────
MODE=
FIRST_BLOCK=
LAST_BLOCK=

# ─── Shared (duplicated from root .env.example for standalone convenience) ─────
ALGOD_SERVER=https://mainnet-api.4160.nodely.dev
ALGOD_PORT=443
ALGOD_TOKEN=
REGISTRY_APP_ID=3147789458
DATA_PATH=data
CONCURRENCY=5

S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_BUCKET_NAME=xgov-committees
S3_ENDPOINT=
S3_PUBLIC_URL=
