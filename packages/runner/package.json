{
  "name": "xgov-committee-runner",
  "version": "1.0.0",
  "description": "Service runner for xGov automated committee generation",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start:prod": "node dist/index.js",
    "start": "tsx index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "bash test/unit/run-unit.sh",
    "test:integration": "vitest run test/integration"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
